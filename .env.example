# Copy to .env (git-ignored) and fill in. Two helpers populate most of this:
#   go run ./cmd/oauth            — Volvo OAuth2 PKCE flow, writes VOLVO_* fields.
#   go run ./cmd/tibber-discover  — Tibber login + vehicle list, writes TIBBER_* fields.

# ─── Volvo (from developer.volvocars.com + the oauth CLI) ──────────────────
VOLVO_CLIENT_ID=
VOLVO_CLIENT_SECRET=
VOLVO_API_KEY=
VOLVO_VIN=
VOLVO_REFRESH_TOKEN=

# ─── Tibber (undocumented app API — same email/password as the Tibber app) ─
# Leave blank to disable the Tibber push; monitor will still log Volvo state.
TIBBER_EMAIL=
TIBBER_PASSWORD=
TIBBER_HOME_ID=
TIBBER_VEHICLE_ID=
TIBBER_VEHICLE_NAME=

# ─── Runtime tunables ──────────────────────────────────────────────────────
POLL_INTERVAL=3h
TOKEN_STORE_PATH=/data/token.json
TIBBER_TOKEN_STORE_PATH=/data/tibber-token.json
HTTP_ADDR=:8080
