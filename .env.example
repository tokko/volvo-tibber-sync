# Copy to .env (git-ignored) and fill in — or run `oauth` to generate it.
# All values are obtained from developer.volvocars.com after you register an
# application and link Ragnar's VIN.

VOLVO_CLIENT_ID=
VOLVO_CLIENT_SECRET=
VOLVO_API_KEY=
VOLVO_VIN=
VOLVO_REFRESH_TOKEN=

# How often to poll. Go duration string (e.g. 30m, 1h, 3h).
POLL_INTERVAL=3h

# Where the service persists refreshed tokens so restarts don't force re-auth.
# Mapped to a Docker volume by default.
TOKEN_STORE_PATH=/data/token.json

# Local HTTP server exposing /healthz and /state (latest charge snapshot).
HTTP_ADDR=:8080
